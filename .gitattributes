# Auto-detect text files and normalize line endings to LF in the repo.
# Git will convert to CRLF on checkout on Windows (if core.autocrlf=true),
# but this silences the warnings during `git add`.
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.gz binary
